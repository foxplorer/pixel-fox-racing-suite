# Optional server settings. These are the defaults used by local development.
PORT=9000
CORS_ORIGINS=http://localhost:5173

# Use dummy for open-source development without keys, funds, or PostgreSQL.
TRANSACTION_MODE=dummy

# Optional inscription branding defaults.
INSCRIPTION_APP=pixelfoxracing
RACE_RESULT_INSCRIPTION_NAME=pixelracingtimes

# ---------------------------------------------------------------------------
# Real mode
# ---------------------------------------------------------------------------
# Set TRANSACTION_MODE=real and configure the values below to exercise every
# transaction route. Do not commit a populated .env file.
#
# PostgreSQL payment UTXO store:
# DATABASE_URL=postgres://...
#
# Transaction keys and destinations:
# GROUP_SIGNING_WIF signs Sigma issuer proofs and supplies the stateless BRC-42
# sender identity. PAYMENT_WIF must control the reserved payment UTXOs.
# GROUP_SIGNING_WIF=...
# PAYMENT_WIF=...
# CHANGE_ADDRESS=...
# PIXELRACING_RESULTS_ADDRESS=...
#
# Collection origins. Each value is required only when its collectible route
# is used; configure all three to support the complete game.
# BLUEBERRIES_COLLECTION_ID=...
# SALAD_COLLECTION_ID=...
# RABBIT_COLLECTION_ID=...
#
# Optional funding overrides. These defaults match transaction-server/schema.sql.
PAYMENT_UTXO_TABLE=payment_utxos
PAYMENT_UTXO_POOL=default
SDK_FEE_RATE_SAT_PER_KB=100
BSV_NETWORK=main
# WHATSONCHAIN_API_KEY=...
# DB_POOL_MAX=5
# DB_POOL_MIN=1

# Identity delivery is enabled automatically in real mode when GROUP_SIGNING_WIF
# is configured. Key derivation is stateless; no server wallet database is used.
