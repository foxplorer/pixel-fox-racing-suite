PORT=9000
CORS_ORIGINS=http://localhost:5173

# Default is dummy mode: no DATABASE_URL, WIFs, or pay UTXOs required.
TRANSACTION_MODE=dummy

# MAP metadata written to new lap-result inscriptions.
INSCRIPTION_APP=pixelfoxracing
RACE_RESULT_INSCRIPTION_NAME=pixelracingtimes

# Set TRANSACTION_MODE=real to create and broadcast real inscriptions.
# DATABASE_URL=postgres://...
# GROUP_SIGNING_WIF=...
# PAYMENT_WIF=...
# CHANGE_ADDRESS=...
# PIXELRACING_RESULTS_ADDRESS=...
# BLUEBERRIES_COLLECTION_ID=...
# SALAD_COLLECTION_ID=...
# RABBIT_COLLECTION_ID=...
